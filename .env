# 镜像与基础配置
OPENCLAW_IMAGE=openclaw:local

# 将配置、工作区、技能全部整合进 data 目录，实现单一挂载点
OPENCLAW_CONFIG_DIR=./data

# 绑定模式：Docker 环境固定使用 lan
OPENCLAW_GATEWAY_BIND=lan

# 宿主机代码根目录 (请修改为你 Mac 上的实际路径)
OPENCLAW_PROJECTS_DIR=~/app/src/go

# 安全令牌（建议修改为你自己的复杂密码）
OPENCLAW_GATEWAY_TOKEN=

# 渠道配置：填入你保留的 TG Bot Token
TELEGRAM_BOT_TOKEN=

# GitHub
GITHUB_TOKEN=

# ClawHub Token
CLAWHUB_TOKEN=